{
  "model_name": "unsloth/Meta-Llama-3.1-8B-Instruct",
  "output_dir": "./output_peft/llama3.1-8b",
  "data_path": "data/raw/train.jsonl",
  "max_seq_len": 2048,
  "lora_rank": 16,
  "lora_alpha": 16,
  "lora_dropout": 0.1,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "batch_size": 1,
  "grad_accum": 8,
  "learning_rate": 2e-4,
  "num_epochs": 3,
  "warmup_steps": 10,
  "optimizer": "paged_adamw_8bit",
  "adam_beta2": 0.999,
  "lr_scheduler": "constant",
  "max_grad_norm": 0.3,
  "quantization": "nf4",
  "double_quant": true,
  "compute_dtype": "bfloat16"
}
