{
  "model_name": "microsoft/Phi-3.5-mini-instruct",
  "output_dir": "./output_peft/phi-3.5-mini",
  "data_path": "data/raw/train.jsonl",
  "max_seq_len": 2048,
  "lora_rank": 16,
  "lora_alpha": 16,
  "lora_dropout": 0.1,
  "target_modules": ["q_proj", "k_proj", "v_proj", "o_proj", "gate_proj", "up_proj", "down_proj"],
  "batch_size": 1,
  "grad_accum": 8,
  "learning_rate": 2e-4,
  "num_epochs": 3,
  "warmup_steps": 10,
  "optimizer": "paged_adamw_8bit",
  "adam_beta2": 0.999,
  "lr_scheduler": "constant",
  "max_grad_norm": 0.3,
  "quantization": "nf4",
  "double_quant": false,
  "compute_dtype": "bfloat16",
  "attn_implementation": "eager",
  "trust_remote_code": false,
  "note": "Requires modeling_phi3_fixed.py — see src/modeling_phi3_fixed.py for DynamicCache compatibility patch"
}
